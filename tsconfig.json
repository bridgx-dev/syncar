{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Workspace path mappings
    "paths": {
      "@synnel/types": ["./packages/types/src"],
      "@synnel/lib": ["./packages/lib/src"],
      "@synnel/core": ["./packages/core/src"],
      "@synnel/client": ["./packages/client/src"],
      "@synnel/server": ["./packages/server/src"],
      "@synnel/react": ["./packages/react/src"],
      "@synnel/adapter": ["./packages/adapter/src"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}

{
  "name": "@synnel/core",
  "version": "1.0.0-alpha.1",
  "description": "Platform-agnostic core for Synnel real-time synchronization",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./ws-server": {
      "types": "./dist/ws-server.d.ts",
      "bun": "./src/ws-server.ts",
      "development": "./src/ws-server.ts",
      "import": "./dist/ws-server.js",
      "default": "./src/ws-server.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "realtime",
    "websocket",
    "synchronization",
    "pubsub"
  ],
  "author": "Synnel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}

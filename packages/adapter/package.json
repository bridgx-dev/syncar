{
  "name": "@synnel/adapter",
  "version": "1.0.0-alpha.1",
  "description": "WebSocket transport adapter for Synnel",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "bun": "./src/client.ts",
      "development": "./src/client.ts",
      "import": "./dist/client.js",
      "default": "./src/client.ts"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "bun": "./src/server.ts",
      "development": "./src/server.ts",
      "import": "./dist/server.js",
      "default": "./src/server.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "websocket",
    "transport",
    "realtime",
    "synnel"
  ],
  "author": "Synnel",
  "license": "MIT",
  "dependencies": {
    "@synnel/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.5.13",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "peerDependencies": {
    "typescript": "^5",
    "ws": "^8.0.0"
  }
}
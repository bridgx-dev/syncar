{
  "name": "@synnel/server",
  "version": "1.0.0-alpha.1",
  "description": "Node.js server for Synnel real-time synchronization",
  "author": "M16BAPPI - [m16bappi@gmail.com]",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "websocket",
    "realtime",
    "server",
    "synnel",
    "pubsub",
    "broadcast"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
{
  "name": "synnel-chat-example",
  "version": "1.0.0",
  "type": "module",
  "description": "Synnel Chat Example - Full stack demo with server and React client",
  "scripts": {
    "dev": "concurrently \"bun run server\" \"bun run client\"",
    "server": "bun run server/index.ts",
    "client": "vite",
    "build": "bun run build:server && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@synnel/core": "workspace:*",
    "@synnel/adapter": "workspace:*",
    "@synnel/client": "workspace:*",
    "@synnel/react": "workspace:*",
    "@synnel/server": "workspace:*",
    "express": "^4.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.2.3"
  }
}

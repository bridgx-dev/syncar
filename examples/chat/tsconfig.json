{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@synnel/core": ["../../packages/core/src/index.ts"],
      "@synnel/client": ["../../packages/client/src/index.ts"],
      "@synnel/adapter-ws": ["../../packages/adapter-ws/src/index.ts"],
      "@synnel/react": ["../../packages/react/src/index.ts"],
      "@synnel/server": ["../../packages/server/src/index.ts"]
    }
  },
  "include": ["client", "server", "vite.config.ts"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/client" },
    { "path": "../../packages/adapter-ws" },
    { "path": "../../packages/react" },
    { "path": "../../packages/server" }
  ]
}
